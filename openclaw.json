{
  "gateway": {
    "mode": "local",
    "port": 18789
  },
  "channels": {
    "telegram": {
      "groupPolicy": "allowlist",
      "dmPolicy": "allowlist",
      "allowlist": [
        "6868150391"
      ]
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "groq/llama-3.3-70b-versatile"
      },
      "memorySearch": {
        "provider": "local"
      }
    }
  },
  "skills": {
    "openprose": {
      "stateMode": "postgres",
      "postgres": {
        "connection": "${DATABASE_URL}"
      }
    }
  }
}
